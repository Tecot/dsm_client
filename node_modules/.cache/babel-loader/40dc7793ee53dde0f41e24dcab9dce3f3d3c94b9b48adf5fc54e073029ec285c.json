{"ast":null,"code":"import \"core-js/modules/es.object.to-string.js\";\nimport config from '@/config';\nimport axios from 'axios';\nimport { showLoading, hideLoading } from '@/utils/loading';\nimport SrpDescription from '@/components/database/bioproject/SrpDescription.vue';\nimport RunInformation from '@/components/database/bioproject/RunInformation.vue';\nimport RunInfoDescription from '@/components/database/bioproject/RunInfoDescription.vue';\nimport ContigsInformation from '@/components/database/bioproject/ContigsInformation.vue';\nexport default {\n  name: 'RunProject',\n  data: function data() {\n    return {\n      srp: '',\n      srpInfo: {},\n      runInfo: {},\n      runDetailData: {},\n      runDetailVisible: false\n    };\n  },\n  components: {\n    SrpDescription: SrpDescription,\n    RunInformation: RunInformation,\n    RunInfoDescription: RunInfoDescription,\n    ContigsInformation: ContigsInformation\n  },\n  mounted: function mounted() {\n    var param = this.$route.params['param'];\n    var databaseRunProjectData = this.$store.state.databaseRunProjectData;\n    if (param['SRAStudy']) {\n      if (databaseRunProjectData) {\n        if (databaseRunProjectData.srpInfo['SRAStudy'] == param['SRAStudy']) {\n          this.srpInfo = databaseRunProjectData.srpInfo;\n          this.runInfo = databaseRunProjectData.runInfo;\n        } else {\n          this.srpInfo = param;\n          this.requestRunProjectInfo(this.srpInfo['SRAStudy']);\n        }\n      } else {\n        this.srpInfo = param;\n        this.requestRunProjectInfo(this.srpInfo['SRAStudy']);\n      }\n    } else {\n      this.srpInfo = databaseRunProjectData.srpInfo;\n      this.runInfo = databaseRunProjectData.runInfo;\n    }\n  },\n  methods: {\n    requestRunProjectInfo: function requestRunProjectInfo(srp) {\n      var _this = this;\n      showLoading();\n      var url = config.baseUrl + config.uri.runProjectViewURI + '/' + srp;\n      axios.get(url, {\n        headers: {\n          'Content-Type': 'application/json; charset=utf-8'\n        }\n      }).then(function (response) {\n        _this.runInfo = response.data;\n        _this.$store.dispatch('setDatabaseRunProjectData', {\n          'srpInfo': _this.srpInfo,\n          'runInfo': _this.runInfo\n        });\n      })[\"finally\"](function () {\n        hideLoading();\n      });\n    },\n    viewDetail: function viewDetail(value) {\n      this.runDetailData = value;\n      this.runDetailVisible = true;\n    }\n  }\n};","map":{"version":3,"names":["config","axios","showLoading","hideLoading","SrpDescription","RunInformation","RunInfoDescription","ContigsInformation","name","data","srp","srpInfo","runInfo","runDetailData","runDetailVisible","components","mounted","param","$route","params","databaseRunProjectData","$store","state","requestRunProjectInfo","methods","_this","url","baseUrl","uri","runProjectViewURI","get","headers","then","response","dispatch","viewDetail","value"],"sources":["src/views/database/bioproject/RunProject.vue"],"sourcesContent":["<template>\n  <div class=\"srp-detail-container\">\n    <div class=\"srp-description-container\">\n      <div class=\"title\">\n        SRP description\n      </div>\n      <SrpDescription :srpData=\"srpInfo\"></SrpDescription>\n    </div>\n\n    <div class=\"run-info-container\">\n      <div class=\"title-container\">\n        <div class=\"title\">\n          Run informations\n        </div>\n        <div class=\"statistics\">\n          {{ 'Run numbers: ' + (Object.keys(runInfo).length? runInfo.data.length : 0) }}\n        </div>\n      </div>\n      \n      <RunInformation :runData=\"runInfo\" @output-value=\"viewDetail($event)\"></RunInformation>\n    </div>\n    \n    <div class=\"geneome-information-container\">\n      <ContigsInformation :srp=\"srpInfo['SRAStudy']\"></ContigsInformation>\n    </div>\n\n    <el-dialog :visible.sync=\"runDetailVisible\">\n      <RunInfoDescription :runDetailData=\"runDetailData\"></RunInfoDescription>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport config from '@/config'\nimport axios from 'axios';\nimport { showLoading, hideLoading } from '@/utils/loading'\nimport SrpDescription from '@/components/database/bioproject/SrpDescription.vue'\nimport RunInformation from '@/components/database/bioproject/RunInformation.vue'\nimport RunInfoDescription from '@/components/database/bioproject/RunInfoDescription.vue'\nimport ContigsInformation from '@/components/database/bioproject/ContigsInformation.vue';\n\nexport default {\n  name: 'RunProject',\n\n  data() {\n    return {\n      srp: '',\n      srpInfo: {},\n      runInfo: {},\n      runDetailData: {},\n      runDetailVisible: false\n    };\n  },\n\n  components: {\n    SrpDescription,\n    RunInformation,\n    RunInfoDescription,\n    ContigsInformation\n  },\n\n  mounted() {\n    const param = this.$route.params['param']\n    const databaseRunProjectData = this.$store.state.databaseRunProjectData\n    if(param['SRAStudy']) {\n      if(databaseRunProjectData) {\n        if(databaseRunProjectData.srpInfo['SRAStudy'] == param['SRAStudy']) {\n          this.srpInfo = databaseRunProjectData.srpInfo\n          this.runInfo = databaseRunProjectData.runInfo\n        } else {\n          this.srpInfo = param\n          this.requestRunProjectInfo(this.srpInfo['SRAStudy'])\n        }\n      } else {\n        this.srpInfo = param\n        this.requestRunProjectInfo(this.srpInfo['SRAStudy'])\n      }\n      \n    } else {\n      this.srpInfo = databaseRunProjectData.srpInfo\n      this.runInfo = databaseRunProjectData.runInfo\n    }\n  },\n\n  methods: {\n\n    requestRunProjectInfo(srp) {\n      showLoading()\n      const url = config.baseUrl + config.uri.runProjectViewURI + '/' + srp\n      axios.get(url, {\n        headers: {\n          'Content-Type': 'application/json; charset=utf-8' \n        }\n      }).then((response) => {\n        this.runInfo = response.data\n        this.$store.dispatch('setDatabaseRunProjectData', {\n          'srpInfo': this.srpInfo, \n          'runInfo': this.runInfo\n        })\n      }).finally(() => {\n        hideLoading()\n      })\n    },\n\n    viewDetail(value) {\n      this.runDetailData = value\n      this.runDetailVisible = true\n    }\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.srp-detail-container {\n  padding-left: 100px;\n  padding-right: 100px;\n\n  .srp-description-container, .run-info-container, .geneome-information-container {\n    margin-top: 10px;\n    background-color: #FFF;\n    border-radius: 5px 5px 5px 5px;\n    padding: 10px 10px 10px 10px;\n    box-shadow: 5px 5px 5px #ccc;\n    .title {\n      height: 40px;\n      line-height: 40px;\n      font-size: 18px;\n      font-weight: bold;\n      color: #36A3F7;\n    }\n    .title-container {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      .statistics {\n        height: 40px;\n        line-height: 40px;\n        font-size: 14px;\n      }\n    }\n    \n  }\n\n  .geneome-information-container {\n    margin-bottom: 20px;\n  }\n}\n\n</style>"],"mappings":";AAiCA,OAAAA,MAAA;AACA,OAAAC,KAAA;AACA,SAAAC,WAAA,EAAAC,WAAA;AACA,OAAAC,cAAA;AACA,OAAAC,cAAA;AACA,OAAAC,kBAAA;AACA,OAAAC,kBAAA;AAEA;EACAC,IAAA;EAEAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;MACAC,OAAA;MACAC,OAAA;MACAC,aAAA;MACAC,gBAAA;IACA;EACA;EAEAC,UAAA;IACAX,cAAA,EAAAA,cAAA;IACAC,cAAA,EAAAA,cAAA;IACAC,kBAAA,EAAAA,kBAAA;IACAC,kBAAA,EAAAA;EACA;EAEAS,OAAA,WAAAA,QAAA;IACA,IAAAC,KAAA,QAAAC,MAAA,CAAAC,MAAA;IACA,IAAAC,sBAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAF,sBAAA;IACA,IAAAH,KAAA;MACA,IAAAG,sBAAA;QACA,IAAAA,sBAAA,CAAAT,OAAA,gBAAAM,KAAA;UACA,KAAAN,OAAA,GAAAS,sBAAA,CAAAT,OAAA;UACA,KAAAC,OAAA,GAAAQ,sBAAA,CAAAR,OAAA;QACA;UACA,KAAAD,OAAA,GAAAM,KAAA;UACA,KAAAM,qBAAA,MAAAZ,OAAA;QACA;MACA;QACA,KAAAA,OAAA,GAAAM,KAAA;QACA,KAAAM,qBAAA,MAAAZ,OAAA;MACA;IAEA;MACA,KAAAA,OAAA,GAAAS,sBAAA,CAAAT,OAAA;MACA,KAAAC,OAAA,GAAAQ,sBAAA,CAAAR,OAAA;IACA;EACA;EAEAY,OAAA;IAEAD,qBAAA,WAAAA,sBAAAb,GAAA;MAAA,IAAAe,KAAA;MACAvB,WAAA;MA