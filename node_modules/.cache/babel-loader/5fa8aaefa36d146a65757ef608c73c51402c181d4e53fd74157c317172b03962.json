{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.object.to-string.js\";\nimport axios from 'axios';\nimport config from '@/config';\nimport { showLoading, hideLoading } from '@/utils/loading';\nexport default {\n  name: 'SrpInformation',\n  data: function data() {\n    return {\n      headerCellStyle: {\n        textAlign: 'center',\n        backgroundColor: '#E9ECEF',\n        color: '#44546A'\n      },\n      cellStyle: {\n        textAlign: 'center'\n      },\n      displayOriginalTable: true,\n      tableData: [],\n      header: [],\n      currentPage: 1,\n      pageSize: 20,\n      total: 0\n    };\n  },\n  mounted: function mounted() {\n    this.requestBioProjectInfo(this.currentPage, this.pageSize);\n  },\n  methods: {\n    requestBioProjectInfo: function requestBioProjectInfo(currentPage, pageSize) {\n      var _this = this;\n      showLoading();\n      var url = config.baseUrl + config.uri.srpProjectViewURI + '/' + currentPage + '/' + pageSize;\n      return axios.get(url, {\n        headers: {\n          'Content-Type': 'application/json; charset=utf-8'\n        }\n      }).then(function (response) {\n        _this.header = response.data.header;\n        _this.tableData = response.data.data;\n        _this.total = response.data.total;\n      })[\"finally\"](function () {\n        hideLoading();\n      });\n    },\n    handleSizeChange: function handleSizeChange(value) {\n      this.pageSize = value;\n      this.currentPage = 1;\n      this.requestBioProjectInfo(this.currentPage, this.pageSize);\n    },\n    handleCurrentChange: function handleCurrentChange(value) {\n      this.currentPage = value;\n      this.requestBioProjectInfo(this.currentPage, this.pageSize);\n    },\n    handleDetail: function handleDetail(value) {\n      this.$router.push({\n        name: 'runproject',\n        params: {\n          param: value\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["axios","config","showLoadin