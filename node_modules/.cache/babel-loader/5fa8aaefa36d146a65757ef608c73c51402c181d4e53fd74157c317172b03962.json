template slot-scope=\"scope\">\n              {{ scope.row['vfs']? scope.row['vfs'].split(';').slice(0, 3).join(';') + '......' : '' }}\n            </template>\n          </el-table-column>\n        <el-table-column prop=\"args\" label=\"ARGs\" width=\"600\"></el-table-column> \n        <el-table-column prop=\"product\" label=\"Secondary Metabolites\" width=\"600\"></el-table-column>\n\n        <!-- amps -->\n        \n        <el-table-column label=\"Option\" width=\"100\" class-name=\"header-end-cell\" fixed=\"right\">\n          <template slot-scope=\"scope\">\n            <el-button type=\"primary\" size=\"mini\" @click=\"handleDetail(scope.row)\">\n              Detail\n            </el-button>\n          </template>\n        </el-table-column>\n      </el-table>\n      <div class=\"pagination-container\">\n        <el-pagination\n          @size-change=\"handleSizeChange\"\n          @current-change=\"handleCurrentChange\"\n          :current-page=\"currentPage\"\n          :page-sizes=\"[20, 50, 100]\"\n          :page-size=\"pageSize\"\n          layout=\"total, prev, pager, next, sizes, jumper\"\n          :total=\"total\"\n        >\n        </el-pagination>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport config from '@/config'\nimport { showLoading, hideLoading } from '@/utils/loading'\n\n\nexport default {\n  name: 'SrpInformation',\n\n  data() {\n    return {\n      headerCellStyle: {\n        textAlign: 'center', \n        backgroundColor: '#E9ECEF', \n        color: '#44546A'\n      },\n      cellStyle: {\n        textAlign: 'center'\n      },\n      displayOriginalTable: true,\n      tableData: [],\n      header: [],\n      currentPage: 1,\n      pageSize: 20,\n      total: 0\n    };\n  },\n\n  mounted() {\n    this.requestBioProjectInfo(this.currentPage, this.pageSize)\n  },\n\n  methods: {\n    requestBioProjectInfo(currentPage, pageSize) {\n      showLoading()\n      const url = config.baseUrl + config.uri.srpProjectViewURI + '/' + currentPage + '/' + pageSize\n      return axios.get(url, {\n        headers: {\n          'Content-Type': 'application/json; charset=utf-8' \n        }\n      }).then((response) => {\n        this.header = response.data.header\n        this.tableData = response.data.data\n        this.total = response.data.total\n      }).finally(() => {\n        hideLoading()\n      })\n    },\n\n    handleSizeChange(value) {\n      this.pageSize = value\n      this.currentPage = 1\n      this.requestBioProjectInfo(this.currentPage, this.pageSize)\n    },\n\n    handleCurrentChange(value) {\n      this.currentPage = value\n      this.requestBioProjectInfo(this.currentPage, this.pageSize)\n    },\n\n    handleDetail(value) {\n      this.$router.push({\n        name: 'runproject', \n        params: { \n          param: value\n        }\n      })\n    }\n  },\n};\n</script>\n\n<style lang=\"scss\"scoped>\n.srp-information-container {\n  .table-container {\n    margin-top: 20px;\n    ::v-deep .header-end-cell>.cell {\n      color: #409EFF;\n      font-size: 14px;\n    }\n    .pagination-container {\n      display: flex;\n      justify-content: center;\n      margin-top: 20px;\n    }\n  }\n}\n</style>"],"mappings":";;AA2DA,OAAAA,KAAA;AACA,OAAAC,MAAA;AACA,SAAAC,WAAA,EAAAC,WAAA;AAGA;EACAC,IAAA;EAEAC,IAAA,WAAAA,KAAA;IACA;MACAC,eAAA;QACAC,SAAA;QACAC,eAAA;QACAC,KAAA;MACA;MACAC,SAAA;QACAH,SAAA;MACA;MACAI,oBAAA;MACAC,SAAA;MACAC,MAAA;MACAC,WAAA;MACAC,QAAA;MACAC,KAAA;IACA;EACA;EAEAC,OAAA,WAAAA,QAAA;IACA,KAAAC,qBAAA,MAAAJ,WAAA,OAAAC,QAAA;EACA;EAEAI,OAAA;IACAD,qBAAA,WAAAA,sBAAAJ,WAAA,EAAAC,QAAA;MAAA,IAAAK,KAAA;MACAlB,WAAA;MACA,IAAAmB,GAAA,GAAApB,MAAA,CAAAqB,OAAA,GAAArB,MAAA,CAAAsB,GAAA,CAAAC,iBAAA,SAAAV,WAAA,SAAAC,QAAA;MACA,OAAAf,KAAA,CAAAyB,GAAA,CAAAJ,GAAA;QACAK,OAAA;UACA;QACA;MACA,GAAAC,IAAA,WAAAC,QAAA;QACAR,KAAA,CAAAP,MAAA,GAAAe,QAAA,CAAAvB,IAAA,CAAAQ,MAAA;QACAO,KAAA,CAAAR,SAAA,GAAAgB,QAAA,CAAAvB,IAAA,CAAAA,IAAA;QACAe,KAAA,CAAAJ,KAAA,GAAAY,QAAA,CAAAvB,IAAA,CAA