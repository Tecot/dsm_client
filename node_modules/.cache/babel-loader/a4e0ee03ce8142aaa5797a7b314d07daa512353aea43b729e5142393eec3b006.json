\n      }).finally(() => {\n        hideLoading()\n      })\n    },\n\n    handleView(value) {\n      // TODO\n      this.$router.push({\n        name: 'contigsdataexpress',\n        params: { \n          param: {\n            ...value,\n            srp: this.srp\n          }\n        }\n      })\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.table-container {\n  .search-container {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    .title-container {\n      font-size: 18px;\n      font-weight: 700;\n      color: #36A3F7;\n    }\n  }\n  .el-table {\n    margin-top: 20px;\n  }\n  .number {\n    display: flex;\n    justify-content: right;\n    align-items: center;\n    margin-top: 20px;\n    color: #44546A;\n  }\n}\n</style>"],"mappings":";;;AAgDA,OAAAA,MAAA;AACA,OAAAC,KAAA;AACA,SAAAC,WAAA,EAAAC,WAAA;AACA,OAAAC,yBAAA;AAEA;EACAC,IAAA;EAEAC,UAAA;IACAF,yBAAA,EAAAA;EACA;EAEAG,KAAA;IACAC,GAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,QAAA;MAAA,oBACAC,SAAA;QACA;MACA;IACA;EACA;EAEAC,IAAA,WAAAA,KAAA;IACA;MACAC,eAAA;QACAC,SAAA;QACAC,eAAA;QACAC,KAAA;MACA;MACAC,SAAA;QACAH,SAAA;MACA;MAEAI,oBAAA;MAEAC,SAAA;MACAC,KAAA;IACA;EACA;EAEAC,KAAA;IACAd,GAAA,WAAAA,IAAAe,QAAA,EAAAC,QAAA;MACA,IAAAD,QAAA;QACA,KAAAE,yBAAA,MAAAjB,GAAA;MACA;IACA;EACA;EAEAkB,OAAA,WAAAA,QAAA;EAEAC,OAAA;IACAC,gBAAA,WAAAA,iBAAAC,KAAA;MACA,KAAAV,oBAAA;MACA,KAAAW,UAAA,GAAAC,aAAA,CAAAA,aAAA,KACAF,KAAA;QACArB,GAAA,OAAAA;MAAA,EACA;MACA,KAAAwB,iCAAA,MAAAF,UAAA;IACA;IAEAG,iBAAA,WAAAA,kBAAAJ,KAAA;MACA,SAAAV,oBAAA;QACA,KAAAA,oBAAA;QACA,KAAAM,yBAAA,MAAAjB,GAAA;MACA;IACA;IAEAwB,iCAAA,WAAAA,kCAAAE,gBAAA;MAAA,IAAAC,KAAA;MACAjC,WAAA;MACA,IAAAkC,GAAA,GAAApC,MAAA,CAAAqC,OAAA,GAAArC,MAAA,CAAAsC,GAAA,CAAAC,iCAAA;MACAtC,KAAA,CAAAuC,GAAA,CAAAJ,GAAA;QACAK,OAAA;UACA;QACA;QACAC,MAAA,EAAAX,aAAA,KACAG,gBAAA;MAEA,GAAAS,IAAA,WAAAC,QAAA;QACAT,KAAA,CAAAf,SAAA,GAAAwB,QAAA,CAAA/B,IAAA,CAAAA,IAAA;QACAsB,KAAA,CAAAd,KAAA,GAAAuB,QAAA,CAAA/B,IAAA,CAAAQ,KAAA;MACA;QACAlB,WAAA;MACA;IACA;IAGAsB,yBAAA,WAAAA,0BAAAjB,GAA