condition-container\">\n          <div class=\"title\">\n            Name\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.name\"\n              size=\"mini\"\n              placeholder=\"Please input name\"\n            >\n            </el-input>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            ID\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.id\" \n              size=\"mini\"\n              placeholder=\"Please input ID\"\n            >\n            </el-input>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Description\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.description\" \n              size=\"mini\"\n              placeholder=\"Please input description\"\n            >\n            </el-input>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            VFs\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.stitle\" \n              :disabled=\"searchContent.ifSearchStitleUnknown\"\n              size=\"mini\"\n              placeholder=\"Please input stitle\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchStitleUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            ARGs\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.sseqid\" \n              :disabled=\"searchContent.ifSearchSseqidUnknown\"\n              size=\"mini\"\n              placeholder=\"Please input sseqid\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchSseqidUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Genes\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.genes\" \n              :disabled=\"searchContent.ifSearchGenesUnknown\"\n              size=\"mini\"\n              placeholder=\"Please input genes\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchGenesUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Bin\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.bin\"\n              :disabled=\"searchContent.ifSearchBinUnknown\" \n              size=\"mini\"\n              placeholder=\"Please input bin\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchBinUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Taxonome\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.classification\"\n              :disabled=\"searchContent.ifSearchClassificationUnknown\" \n              size=\"mini\"\n              placeholder=\"Please input classification\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchClassificationUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Secondary Metabolites\n          </div>\n          <div class=\"search-container\">\n            <el-input \n              v-model=\"searchContent.product\"\n              :disabled=\"searchContent.ifSearchProductUnknown\" \n              size=\"mini\"\n              placeholder=\"Please input secondary metabolites\"\n            >\n            </el-input>\n          </div>\n          <div class=\"known-checked\">\n            <el-checkbox \n              v-model=\"searchContent.ifSearchProductUnknown\">\n              Contain unknown?\n            </el-checkbox>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            Length range:  {{ '[' + searchContent.lengthRange[0] + ' bp , ' + searchContent.lengthRange[1] + ' bp]' }}\n          </div>\n          <div class=\"search-container\">\n            <el-slider\n              range\n              show-stops\n              v-model=\"searchContent.lengthRange\"\n              :max=\"5000\"\n              :min=\"0\"\n              :format-tooltip=\"(value) => value + ' bp' \"\n            >\n            </el-slider>\n          </div>\n        </div>\n\n        <div class=\"search-condition-container\">\n          <div class=\"title\">\n            GC content range:  {{ '[' + searchContent.gcRange[0] + '% , ' + searchContent.gcRange[1] + '%]' }}\n          </div>\n          <div class=\"search-container\">\n            <el-slider\n              range\n              show-stops\n              v-model=\"searchContent.gcRange\"\n              :max=\"100\"\n              :min=\"0\"\n              :format-tooltip=\"(value) => value + '%' \"\n            >\n            </el-slider>\n          </div>\n        </div>\n        \n        <div class=\"button-container\">\n          <el-button size=\"mini\" type=\"danger\" @click=\"searchConfirm\">\n            Confirm\n          </el-button>\n          <el-button size=\"mini\" type=\"primary\" @click=\"searchConditionsReset\">\n            Reset\n          </el-button>\n        </div>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport config from '@/config'\nimport axios from 'axios';\n\nexport default {\n  name: 'ContigsProjectSearch',\n\n  data() {\n    return {\n      srp: '',\n      srps: [],\n      searchConditionsVisible: false,\n\n      searchContent: {\n        name: '',\n        id: '',\n        description: '',\n        stitle: '',\n        sseqid: '',\n        genes: '',\n        bin: '',\n        classification: '',\n        product: '',\n        lengthRange: [0, 6000],\n        gcRange: [0, 100],\n        ifSearchStitleUnknown: false,\n        ifSearchSseqidUnknown: false,\n        ifSearchGenesUnknown: false,\n        ifSearchBinUnknown: false,\n        ifSearchClassificationUnknown: false,\n        ifSearchProductUnknown: false\n      }\n    };\n  },\n\n  mounted() {\n    this.requestSrpDirNames()\n  },\n\n  methods: {\n    async requestSrpDirNames() {\n      const url = config.baseUrl + config.uri.srpDirNamesViewURI\n      axios.get(url, {\n        headers: {\n          'Content-Type': 'application/json; charset=utf-8' \n        }\n      }).then((response) => {\n        this.srps = response.data.data\n        this.srp = this.srps[0]\n        this.$emit('outputSrp', this.srp)\n      })\n    },\n\n    handleChangedSrp() {\n      this.$emit('outputSrp', this.srp)\n    },\n\n    reset() {\n      this.$emit('outputResetSignal', true)\n    },\n\n    searchConfirm() {\n      this.searchConditionsVisible = false\n      this.$emit('outputSearchData', {\n        name: this.searchContent.name,\n        id: this.searchContent.id,\n        description: this.searchContent.description,\n        stitle: this.searchContent.stitle,\n        sseqid: this.searchContent.sseqid,\n        genes: this.searchContent.genes,\n        bin: this.searchContent.bin,\n        classification: this.searchContent.classification,\n        product: this.searchContent.product,\n        lengthLow: this.searchContent.lengthRange[0],\n        lengthHigh: this.searchContent.lengthRange[1],\n        gcLow: this.searchContent.gcRange[0],\n        gcHigh: this.searchContent.gcRange[1],\n        ifSearchStitleUnknown: this.searchContent.ifSearchStitleUnknown,\n        ifSearchSseqidUnknown: this.searchContent.ifSearchSseqidUnknown,\n        ifSearchGenesUnknown: this.searchContent.ifSearchGenesUnknown,\n        ifSearchBinUnknown: this.searchContent.ifSearchBinUnknown,\n        ifSearchClassificationUnknown: this.searchContent.ifSearchClassificationUnknown,\n        ifSearchProductUnknown: this.searchContent.ifSearchProductUnknown\n      })\n    },\n\n    searchConditionsReset() {\n      this.searchContent = {\n          name: '',\n          id: '',\n          description: '',\n          stitle: '',\n          Sseqid: '',\n          genes: '',\n          bin: '',\n          classification: '',\n          product: '',\n          lengthRange: [0, 6000],\n          gcRange: [0, 100],\n          ifSearchStitleUnknown: false,\n          ifSearchSseqidUnknown: false,\n          ifSearchGenesUnknown: false,\n          ifSearchBinUnknown: false,\n          ifSearchClassificationUnknown: false,\n          ifSearchProductUnknown: false\n        }\n    }\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.search {\n  .search-option {\n    display: flex;\n    justify-content: right;\n    span {\n      font-size: 18px;\n    }\n    .el-select {\n      margin-right: 10px;\n    }\n  }\n  .contigs-project-search-conditions-container {\n\n    .known-checked {\n      display: flex;\n      justify-content: end;\n    } \n\n    .search-condition-container {\n      margin-top: 5px;\n      .title {\n        font-size: 14px;\n      }\n      .search-container {\n        margin-top: 5px;\n      }\n    }\n\n    .button-container {\n      display: flex;\n      justify-content: center;\n      margin-top: 20px;\n    }\n  }\n}\n</style>"],"mappings":";;;;;AAkQA,OAAAA,MAAA;AACA,OAAAC,KAAA;AAEA;EACAC,IAAA;EAEAC,IAAA,WAAAA,KAAA;IACA;MACAC,GAAA;MACAC,IAAA;MACAC,uBAAA;MAEAC,aAAA;QACAL,IAAA;QACAM,EAAA;QACAC,WAAA;QACAC,MAAA;QACAC,MAAA;QACAC,KAAA;QACAC,GAAA;QACAC,cAAA;QACAC,OAAA;QACAC,WAAA;QACAC,OAAA;QACAC,qBAAA;QACAC,qBAAA;QACAC,oBAAA;QACAC,kBAAA;QACAC,6BAAA;QACAC,sBAAA;MACA;IACA;EACA;EAEAC,OAAA,WAAAA,QAAA;IACA,KAAAC,kBAAA;EACA;EAEAC,OAAA;IACAD,kBAAA,WAAAA,mBAAA;MAAA,IAAAE,KAAA;MAAA,OAAAC,iBAAA,cAAAC,YAAA,GAAAC,CAAA,UAAAC,QAAA;QAAA,IAAAC,GAAA;QAAA,OAAAH,YAAA,GAAAI,CAAA,WAAAC,QAAA;UAAA,kBAAAA,QAAA,CAAAC,CAAA;YAAA;cACAH,GAAA,GAAAhC,MAAA,CAAAoC,OAAA,GAAApC,MAAA,CAAAqC,GAAA,CAAAC,kBAAA;cACArC,KAAA,CAAAsC,GAAA,CAAAP,GAAA;gBACAQ,OAAA;kBACA;gBACA;cACA,GAAAC,IAAA,WAAAC,QAAA;gBACAf,KAAA,CAAAtB,IAAA,GAAAqC,QAAA,CAAAvC,IAAA,CAAAA,IAAA;gBACAwB,KAAA,CAAAvB,GAAA,GAAAuB,KAAA,CAAAtB,IAAA;gBACAsB,KAAA,CAAAgB,KAAA,cAAAhB,KAAA,CAAAvB,GAAA;cACA;YAAA;cAAA,OAAA8B,QAAA,CAAAU,CAAA;UAAA;QAAA,GAAAb,OAAA;MAAA;IACA;IAEAc,gBAAA,WAAAA,iBAAA;MACA,KAAAF,KAAA,mBAAAvC,GAAA;IACA;IAEA0C,KAAA,WAAAA,MAAA;MACA,KAAAH,KAAA;IACA;IAEAI,aAAA,WAAAA,cAAA;MACA,KAAAzC,uBAAA;MACA,KAAAqC,KAAA;QACAzC,IAAA,OAAAK,aAAA,CAAAL,IAAA;QACAM,EAAA,OAAAD,aAAA,CAAAC,EAAA;QACAC,WAAA,OAAAF,aAAA,CAAAE,WAAA;QACAC,MAAA,OAAAH,aAAA,CAAAG,MAAA;QACAC,MAAA,OAAAJ,aAAA,CAAAI,MAAA;QACAC,KAAA,OAAAL,aAAA,CAAAK,KAAA;QACAC,GAAA,OAAAN,aAAA,CAAAM,GAAA;QACAC,cAAA,OAAAP,aAAA,CAAAO,cAAA;QACAC,OAAA,OAAAR,aAAA,CA