{"ast":null,"code":"export default {\n  name: 'GeoSearchConditions',\n  data: function data() {\n    return {\n      depthRange: [0, 6000],\n      weRange: [-180, 180],\n      snRange: [-90, 90],\n      searchMemory: {\n        depthRange: [0, 6000],\n        weRange: [-180, 180],\n        snRange: [-90, 90]\n      }\n    };\n  },\n  mounted: function mounted() {},\n  methods: {\n    searchConfirm: function searchConfirm() {\n      var depthFalg = this.searchMemory.depthRange[0] === this.depthRange[0] && this.searchMemory.depthRange[1] === this.depthRange[1];\n      var weRangeFlag = this.searchMemory.weRange[0] === this.weRange[0] && this.searchMemory.weRange[1] === this.weRange[1];\n      var snRangeFlag = this.searchMemory.snRange[0] === this.snRange[0] && this.searchMemory.snRange[1] === this.snRange[1];\n      if (!(depthFalg && weRangeFlag && snRangeFlag)) {\n        var searchData = {\n          depthRange: this.depthRange,\n          weRange: this.weRange,\n          snRange: this.snRange\n        };\n        this.searchMemory = searchData;\n        this.$emit('outputSearchData', searchData);\n      }\n    },\n    searchConditionsReset: function searchConditionsReset() {\n      this.depthRange = [0, 6000];\n      this.weRange = [-180, 180];\n      this.snRange = [-90, 90];\n    },\n    dataReset: function dataReset() {\n      this.$emit('dataReset', {\n        signal: true\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","depthRange","weRange","snRange","searchMemory","mounted","methods","searchConfirm","depthFalg","weRangeFlag","snRangeFlag","searchData","$emit","searchConditionsReset","dataReset","signal"],"sources":["src/components/database/overview/GeoSearchConditions.vue"],"sourcesContent":["<template>\n  <div class=\"srp-search-conditions-container\">\n    <div class=\"depth-search-item\">\n      <div class=\"title\">\n        Depth range\n      </div>\n      <div class=\"search-condition\">\n        <el-slider\n          range\n  